graph TD
    %% Define Styles
    classDef hardware fill:#e0f2fe,stroke:#0284c7,stroke-width:2px,color:#0f172a
    classDef server fill:#fef08a,stroke:#ca8a04,stroke-width:2px,color:#0f172a
    classDef sensor fill:#dcfce3,stroke:#16a34a,stroke-width:1px,color:#0f172a
    classDef user fill:#f3e8ff,stroke:#9333ea,stroke-width:2px,color:#0f172a
    classDef ext fill:#fee2e2,stroke:#dc2626,stroke-width:1px,color:#0f172a

    %% Nodes
    subgraph Microcontroller ["ESP32-S3 (gembot2.cpp)"]
        ESP[ESP32-S3 Core]
        TFT[Layar TFT ILI9341]
        MPU[MPU6050<br/>Gyro/Accel]
        DHT[Sensor DHT22<br/>Suhu/Lembab]
        DFP[DFPlayer Mini<br/>Audio MP3]
        MIC[INMP441<br/>Mic I2S]
        SPK[MAX98357A<br/>Speaker I2S]
        TOUCH[Touch Sensor]
        BATT[Battery Monitor]
    end

    subgraph Server ["Node.js Server (web_serial_server.js)"]
        Node[Server Utama<br/>Port 3001]
        DB[(SQLite DB<br/>Conversations)]
    end
    
    subgraph Client ["Klien / Pengguna"]
        Web[Web Dashboard<br/>/control]
    end
    
    subgraph External ["Layanan Eksternal"]
        Gemini[Gemini API<br/>LLM & TTS]
    end

    %% Hardware internal connections
    ESP -->|SPI <br/>11,13,12,10,9,14| TFT
    MPU -.->|I2C <br/>SDA:1, SCL:2| ESP
    DHT -.->|GPIO 8| ESP
    ESP <-->|UART <br/>TX:21, RX:18| DFP
    MIC -.->|I2S <br/>SCK:4, WS:5, SD:6| ESP
    ESP -->|I2S <br/>BCLK:15, LRC:16, DOUT:17| SPK
    TOUCH -.->|GPIO 7| ESP
    BATT -.->|ADC GPIO 3| ESP
    
    %% Communication
    ESP <===>|WebSockets / Serial| Node
    Node <===>|HTTP / WebSockets| Web
    Node <-->|API Calls| Gemini
    Node <-->|Read/Write| DB

    %% Apply Styles
    class ESP hardware
    class TFT,MPU,DHT,DFP,MIC,SPK,TOUCH,BATT sensor
    class Node,DB server
    class Web user
    class Gemini ext
